{
  "description": "Fixed-actuator KSTAR-like time evolution using the bundled KSTAR.eqdsk.",
  "machine": {
    "R0": 1.8,
    "a": 0.45,
    "Bt": 2.0,
    "Ip_MA": 1.0,
    "kappa": 1.65,
    "delta": 0.4,
    "Zeff": 2.0,
    "plasma_species": "D",
    "impurity_Z": 6.0
  },
  "actuator": {
    "P_aux_MW": 3.0,
    "nbi_birth_energy_MeV": 0.1,
    "heat_center": 0.2,
    "heat_width": 0.3,
    "cd_efficiency_20": 0.1,
    "greenwald_fraction_target": 0.4,
    "greenwald_edge_density_fraction": 0.2
  },
  "simulation": {
    "nr": 32,
    "ntheta": 32,
    "dt": 1e-3,
    "end_time_s": 1.0,
    "equilibrium_skip_steps": 1,
    "source_skip_steps": 1,
    "transport_skip_steps": 1,
    "pedestal_skip_steps": 1,
    "equilibrium_model": "geqdsk_prescribed",
    "geqdsk_path": "KSTAR.eqdsk",
    "current_evolution_model": "saturated_conductivity",
    "density_evolution_model": "greenwald_feedback",
    "density_boundary_source_width": 0.3,
    "transport_model": "tglfnn_jax",
    "neoclassical_transport_model": "neonn_jax",
    "pedestal_model": "eped1_nn_jax",
    "pedestal_enforcement": "tanh_underlay",
    "pedestal_lh_threshold_model": "delabie",
    "initial_beta_N_target": 1.8,
    "initial_profile_model": "parabolic",
    "include_ohmic_heating": false
  },
  "optimization": {
    "n_iter": 2,
    "gradient_mode": "autodiff",
    "learning_rate": 0.5,
    "objective": ["Q", "Pfus"],
    "objective_weights": [1.0, 0.01],
    "controls": ["Ip_MA", "P_aux_MW"],
    "constraints": [
        {"metric": "q95", "kind": "lower", "value": 3.0, "weight": 10.0},
        {"metric": "beta_N", "kind": "upper", "value": 4.0, "weight": 10.0}
    ]
  }
}
